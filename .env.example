# ──────────────────────────────────────────────────────────────────────────────
# InstaFlow — Environment Configuration Template
# Copy this to .env and fill in your real values.
# .env is gitignored — NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=instaflow
POSTGRES_PASSWORD=your_strong_db_password_here   # REQUIRED
POSTGRES_DB=instaflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                                # Uncomment if Redis is auth-protected

# ── Celery ────────────────────────────────────────────────────────────────────
# These default to redis_url if not set
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_CONCURRENCY=3

# ── Session Vault Encryption ──────────────────────────────────────────────────
# Generate a new key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=your_fernet_key_here        # REQUIRED

# ── Instagram Settings ────────────────────────────────────────────────────────
IG_APP_VERSION=302.1.0.36.111
IG_LOCALE=en_US
IG_TIMEZONE_OFFSET=19800     # UTC+5:30 (IST). UTC=0, EST=-18000, PST=-28800

# ── Telegram Alerting (optional but recommended) ──────────────────────────────
# Get a bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# ── 2Captcha (optional — for automated CAPTCHA solving) ───────────────────────
# CAPTCHA_API_KEY=your_2captcha_api_key_here

# ── Ollama / LLM (optional — not used, comment text is always "link") ─────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_COMMENT_PROBABILITY=0.0  # Set to 0 — we only post "link"

# ── Rate Limits (conservative defaults — do not exceed without caution) ────────
RATE_FOLLOWS_PER_HOUR=10
RATE_FOLLOWS_PER_DAY=50
RATE_COMMENTS_PER_HOUR=12
RATE_COMMENTS_PER_DAY=60
RATE_DM_READS_PER_HOUR=30
